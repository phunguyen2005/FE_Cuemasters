# =============================================
# API
# =============================================

# Base URL of the .NET backend API.
# Must end without trailing slash.
# Local dev default: http://localhost:5235/api
VITE_API_URL=http://localhost:5235/api

# =============================================
# Optional: AI Features (Gemini)
# =============================================

# Required only if Gemini AI features are used.
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to disable AI features.
GEMINI_API_KEY=
